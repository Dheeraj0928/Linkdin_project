# Copy to .env and fill in your values — NEVER commit .env

LINKEDIN_ACCOUNT_ID=default

# Browser
HEADLESS=false
BROWSER_PROFILE_DIR=.browser-profile

# Messaging
MAX_CONNECTIONS=20
MAX_SCROLL_ATTEMPTS=80
DELAY_BETWEEN_PROFILES_MS=5000
DELAY_BETWEEN_PROFILES_MIN_MS=3000
DELAY_BETWEEN_PROFILES_MAX_MS=12000
ACTION_DELAY_MS=200
TYPE_FALLBACK_DELAY_MS=5
PAGE_TIMEOUT_MS=20000
SCROLL_PAUSE_MS=800
SEND_ENABLED=false

# Connect requests
CONNECT_ROLE=Software Engineer
CONNECT_LOCATION=
CONNECT_MAX_PER_RUN=10
CONNECT_DELAY_MS=8000
CONNECT_DELAY_MIN_MS=6000
CONNECT_DELAY_MAX_MS=18000
CONNECT_SEND_ENABLED=true
CONNECT_SEND_NOTE=false
CONNECT_NOTE_FALLBACK=true

# Daily safety limits
DAILY_MESSAGE_LIMIT=25
DAILY_CONNECT_LIMIT=15

# LinkedIn URLs
LINKEDIN_CONNECTIONS_URL=https://www.linkedin.com/mynetwork/invite-connect/connections/

# Your public resume link (used in {ResumeLink})
RESUME_URL=https://your-resume-link-here
