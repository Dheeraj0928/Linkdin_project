# Browser
HEADLESS=false
BROWSER_PROFILE_DIR=.browser-profile

# How many NEW people to message per run (already-sent are skipped automatically)
MAX_CONNECTIONS=500

# How many scroll rounds on connections page to load more profiles
MAX_SCROLL_ATTEMPTS=80

DELAY_BETWEEN_PROFILES_MS=200
ACTION_DELAY_MS=100
TYPE_FALLBACK_DELAY_MS=0
PAGE_TIMEOUT_MS=12000
SCROLL_PAUSE_MS=500

# Safety: keep false until you explicitly want auto-send
SEND_ENABLED=false

# LinkedIn URLs
LINKEDIN_CONNECTIONS_URL=https://www.linkedin.com/mynetwork/invite-connect/connections/

# Public resume link (used in {ResumeLink} placeholder in message.txt)
RESUME_URL=https://drive.google.com/file/d/1G_qTw4hwmWoY9QvmH1935kC4t5iltl32/view?usp=drivesdk
